@using DrinkBuddy.Presentation.Shared.Camera
@using DrinkBuddy.Presentation.Shared.LoadingIndication
@using MudBlazor
@attribute [Route(Path)]

<video autoplay playsinline muted id="v"></video>

<script>
    navigator.mediaDevices.getUserMedia({ video: true })
      .then(s => v.srcObject = s)
      .catch(e => console.error(e));
</script>

<MudPaper Class="pa-4">
    <MudCard>
        <MudCardContent>
            <MudSelect @bind-Value="SelectedSituation"
                       Variant="Variant.Filled"
                       FitContent="true"
                       Class="mb-4"
                       Clearable="false" For="() => SelectedSituation">
                @foreach (var situation in FotoSituation.CreateAll())
                {
                    <MudSelectItem T="FotoSituation" Value="@situation">@situation.Name</MudSelectItem>
                }
            </MudSelect>

            <Camera
                OnPictureTaken="HandlePictureTakenAsync">
            </Camera>
        </MudCardContent>
        <MudCardActions>
            <LoadingButton 
                IsDisabled="IsDisabled"
                IsLoading="IsCalculating" ButtonType="ButtonType.Button" Icon="@Icons.Material.Filled.LocalDrink" OnClick="SuggestDrinkAsync" Class="mx-2"/>
        </MudCardActions>
    </MudCard>
</MudPaper>