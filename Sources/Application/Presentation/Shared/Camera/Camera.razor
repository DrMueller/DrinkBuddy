@using MudBlazor

<div class="container-fluid">
    <div class="row">
        <div class="col">
            <video id="videoElement" autoplay playsinline muted style="width:100%; max-width:600px;"></video>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <canvas id="canvasElement" style="display:none;"></canvas>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartCameraAsync">
                Kamera starten
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="TakePictureAsync">
                Bild aufnehmen
            </MudButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="row mt-2">
            <div class="col">
                <MudAlert Severity="Severity.Error">@_error</MudAlert>
            </div>
        </div>
    }

    <p>
        @_imageDataUrl
    </p>
    @if (!string.IsNullOrWhiteSpace(_imageDataUrl))
    {
        <div class="row mt-3">
            <div class="col">
                <div style="width:512px; height:384px; border:2px solid #ccc; display:flex; align-items:center; justify-content:center;">
                    <MudImage Src="@_imageDataUrl"
                              Style="max-width:100%; max-height:100%; object-fit:contain;" />
                </div>
            </div>
        </div>
    }
</div>