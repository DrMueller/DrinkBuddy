@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
<div style="position:relative; width:200px;">
    <p>
        @_error
    </p>

    <MudButton style="width:100%;">
        Foto aufnehmen
    </MudButton>

    <InputFile id="cameraInput"
               OnChange="OnFileSelectedAsync"
               accept="image/*"
               capture="environment"
               style="
                   position:absolute;
                   top:0;
                   left:0;
                   width:100%;
                   height:100%;
                   opacity:0;
                   cursor:pointer;
               "/>
</div>

@if (!string.IsNullOrWhiteSpace(_imageDataUrl))
{
    <div class="row mt-3">
        <div class="col">
            <div style="width:100%; height:100%; border:2px solid #ccc; display:flex; align-items:center; justify-content:center;">
                <MudImage Src="@_imageDataUrl"
                          Style="max-width:100%; max-height:100%; object-fit:contain;" />
            </div>
        </div>
    </div>
}