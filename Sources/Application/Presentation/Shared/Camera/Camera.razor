@using MudBlazor
<div class="container-fluid">
    <div class="row">
        <div class="col">
            <video id="videoElement" autoplay playsinline muted style="width:100%; max-width:600px;"></video>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <canvas id="canvasElement" style="display:none;"></canvas>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@StartCameraAsync">
                Kamera starten
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="@TakePictureAsync">
                Bild aufnehmen
            </MudButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_imageDataUrl))
    {
        <div class="row mt-3">
            <div class="col">
                <MudImage Src="@_imageDataUrl" Alt="Aufgenommenes Bild" Style="max-width:600px; width:100%;"/>
            </div>
        </div>
    }
</div>